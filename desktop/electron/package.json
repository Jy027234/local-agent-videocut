{
  "name": "smart-video-cut-local-shell",
  "version": "0.1.0",
  "private": true,
  "description": "Electron shell for Smart Video Cut Local Studio",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package:win": "electron-builder --win portable",
    "package": "electron-builder"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "local.smart-video-cut.studio",
    "productName": "Smart Video Cut Local Studio",
    "directories": {
      "output": "../../release/electron"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}
